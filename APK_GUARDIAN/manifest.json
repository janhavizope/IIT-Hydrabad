{
  "manifest_version": 3,
  "name": "APK Guardian",
  "version": "2.0",
  "description": "Intercepts downloads and scans for threats before allowing download.",
  "permissions": [
    "declarativeNetRequest",
    "downloads",
    "storage",
    "tabs",
    "webRequest",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["scanning.html", "alert.html"],
      "matches": ["<all_urls>"]
    }
  ]
}